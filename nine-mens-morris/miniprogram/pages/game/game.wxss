/* 简化版WXSS - 基础样式 */

page {
  width: 100%;
  height: 100%;
  background-color: #0a0a0f;
  color: #ffffff;
}

.game-container {
  width: 100%;
  height: 100%;
  position: relative;
  background: linear-gradient(135deg, #0a0a0f 0%, #12121a 50%, #0a0a0f 100%);
}

.bg-canvas,
.game-canvas {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.bg-canvas {
  z-index: 1;
}

.game-canvas {
  z-index: 2;
}

.ui-layer {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 10;
  pointer-events: none;
}

.ui-layer > view,
.ui-layer > button {
  pointer-events: auto;
}

.game-info {
  position: absolute;
  top: 10px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: flex-start;
  gap: 8px;
  width: 94%;
  padding: 8px 10px;
  background: rgba(10, 10, 15, 0.95);
  border: 1px solid rgba(0, 245, 255, 0.4);
  border-radius: 10px;
  z-index: 100;
}

.game-title-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-bottom: 6px;
}

.game-info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 6px;
}

.title-text {
  font-size: 1.2rem;
  font-weight: 700;
  background: linear-gradient(135deg, #00f5ff, #ff00ff);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.player-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  padding: 4px 8px;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 8px;
  border: 2px solid rgba(255, 255, 255, 0.2);
  flex: 1 1 0;
  min-width: 0;
}

.player-card.active {
  border-color: #00f5ff;
  box-shadow: 0 0 15px rgba(0, 245, 255, 0.5);
}

.player-1.active {
  border-color: #00f5ff;
  box-shadow: 0 0 15px rgba(0, 245, 255, 0.5);
}

.player-2.active {
  border-color: #ff00ff;
  box-shadow: 0 0 15px rgba(255, 0, 255, 0.5);
}

.player-main {
  display: flex;
  align-items: center;
  gap: 6px;
  flex: 0 0 auto;
  min-width: 0;
}

.player-icon {
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: #00f5ff;
}

.p1-icon {
  background: #00f5ff;
}

.p2-icon {
  background: #ff00ff;
}

.player-name {
  font-size: 0.75rem;
}

.player-stats {
  display: flex;
  gap: 8px;
  margin-left: auto;
  justify-content: flex-end;
  flex: 1 1 auto;
}

.stat-box {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-label {
  font-size: 0.5rem;
  color: rgba(255, 255, 255, 0.6);
}

.stat-value {
  font-size: 0.8rem;
  font-weight: bold;
}

.game-status {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 4px 8px;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 6px;
  min-width: 74px;
  flex: 0 0 auto;
}

.phase-text {
  font-size: 0.55rem;
  color: rgba(255, 255, 255, 0.6);
}

.turn-text {
  font-size: 0.7rem;
  color: #00ff88;
}

.game-controls {
  position: absolute;
  bottom: 24px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  width: calc(100% - 24px);
  max-width: 420px;
  z-index: 100;
}

.control-btn {
  flex: 1 1 0;
  min-width: 0;
  height: 42px;
  margin: 0;
  padding: 0 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.12);
  border: 1px solid rgba(255, 255, 255, 0.25);
  border-radius: 8px;
  color: #ffffff;
  font-size: 0.82rem;
  line-height: 1;
  white-space: nowrap;
  box-sizing: border-box;
}

.control-btn::after {
  border: none;
}

.btn-icon {
  font-size: 0.95rem;
  line-height: 1;
  margin-right: 4px;
  opacity: 0.95;
}

.firsthand-menu,
.theme-menu,
.winner-overlay,
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: none;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(10, 10, 15, 0.95);
  z-index: 200;
}

.loading-overlay {
  top: 50%;
  left: 50%;
  width: 220px;
  height: 120px;
  transform: translate(-50%, -50%);
  background: rgba(10, 10, 15, 0.78);
  border: 1px solid rgba(0, 245, 255, 0.35);
  border-radius: 12px;
  pointer-events: none;
}

.firsthand-menu.show,
.firsthand-menu.active,
.theme-menu.show,
.theme-menu.active,
.winner-overlay.show,
.winner-overlay.active,
.loading-overlay.show,
.loading-overlay.active {
  display: flex;
}

.start-menu-header {
  text-align: center;
  margin-bottom: 30px;
}

.menu-logo {
  font-size: 3rem;
  margin-bottom: 10px;
}

.menu-title-main {
  font-size: 2rem;
  background: linear-gradient(135deg, #00f5ff, #ff00ff);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.menu-section {
  margin-bottom: 20px;
  width: 100%;
  max-width: 300px;
}

.section-label {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 10px;
  font-size: 0.9rem;
  color: rgba(255, 255, 255, 0.8);
}

.difficulty-options,
.firsthand-options {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.diff-btn,
.firsthand-btn {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 15px;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 8px;
  color: #ffffff;
  font-size: 0.9rem;
  text-align: left;
}

.diff-btn.selected,
.firsthand-btn.selected {
  background: rgba(0, 245, 255, 0.1);
  border-color: #00f5ff;
}

.diff-icon,
.diff-name {
  flex: 1;
}

.diff-bar {
  width: 60px;
  height: 4px;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 2px;
  overflow: hidden;
}

.diff-fill {
  height: 100%;
  background: linear-gradient(90deg, #00f5ff, #ff00ff);
}

.start-btn {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 15px 40px;
  background: linear-gradient(135deg, #00f5ff, #ff00ff);
  border: none;
  border-radius: 25px;
  color: #ffffff;
  font-size: 1.1rem;
  font-weight: bold;
  margin-top: 20px;
}

.theme-menu .menu-title {
  font-size: 1.5rem;
  margin-bottom: 20px;
}

.theme-btn {
  width: 200px;
  padding: 12px 20px;
  margin: 8px 0;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 8px;
  color: #ffffff;
  font-size: 1rem;
}

.theme-btn.selected {
  background: rgba(0, 245, 255, 0.1);
  border-color: #00f5ff;
}

.winner-content {
  text-align: center;
}

.winner-title {
  font-size: 3rem;
  font-weight: bold;
  background: linear-gradient(90deg, #00ff88, #00f5ff);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 10px;
}

.winner-subtitle {
  font-size: 1.2rem;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 30px;
}

.restart-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12px 30px;
  background: linear-gradient(135deg, #00f5ff, #ff00ff);
  border: none;
  border-radius: 20px;
  color: #ffffff;
  font-size: 1rem;
}

.loading-content {
  text-align: center;
}

.loading-spinner {
  width: 50px;
  height: 50px;
  border: 3px solid rgba(255, 255, 255, 0.1);
  border-top-color: #00f5ff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto 20px;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 1rem;
  color: rgba(255, 255, 255, 0.8);
}

.start-icon,
.restart-icon {
  font-size: 1rem;
  margin-right: 6px;
}

.mobile-hint {
  position: absolute;
  bottom: 100px;
  left: 50%;
  transform: translateX(-50%);
  padding: 8px 15px;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 20px;
  font-size: 0.85rem;
  color: rgba(255, 255, 255, 0.8);
  z-index: 15;
  opacity: 0;
  transition: opacity 0.3s;
}

.mobile-hint.show {
  opacity: 1;
}

/* 移动端响应式 */
@media (max-width: 768px) {
  .game-info {
    gap: 6px;
    padding: 10px;
    top: 10px;
  }

  .game-info-row {
    gap: 4px;
  }
  
  .game-title-bar .title-text {
    font-size: 1.1rem;
  }
  
  .player-card {
    padding: 5px 6px;
    gap: 6px;
  }
  
  .player-icon {
    width: 20px;
    height: 20px;
  }
  
  .player-name {
    font-size: 0.8rem;
  }
  
  .stat-label {
    font-size: 0.5rem;
  }
  
  .stat-value {
    font-size: 0.8rem;
  }
  
  .game-controls {
    bottom: calc(env(safe-area-inset-bottom) + 10px);
    width: calc(100% - 20px);
    gap: 6px;
  }
  
  .control-btn {
    height: 40px;
    padding: 0 6px;
    font-size: 0.76rem;
  }

  .loading-overlay {
    width: 200px;
    height: 110px;
  }
}
